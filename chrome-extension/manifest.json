{
  "manifest_version": 3,
  "name": "Crossly - 跨境选品工具",
  "version": "1.6.0",
  "description": "在Ozon热销页抓取商品，自动去1688/义乌购找货源；在商品页一键导入到选品工具",
  "permissions": ["activeTab", "storage", "clipboardWrite", "scripting"],
  "host_permissions": [
    "https://*.1688.com/*",
    "https://*.ozon.ru/*",
    "https://*.yiwugo.com/*",
    "https://localhost:3000/*",
    "https://*.vercel.app/*",
    "https://*.crossly.cn/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.1688.com/*", "https://*.ozon.ru/*", "https://*.yiwugo.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
