{
  "manifest_version": 3,
  "name": "Crossly 全能管家",
  "version": "2.1.1",
  "description": "跨境小学生全能管家：1688采集+Ozon后台一键装修+仓库参数配置+俄语取名助手",
  "permissions": ["activeTab", "storage", "clipboardWrite", "scripting"],
  "host_permissions": [
    "*://*.1688.com/*",
    "*://*.ozon.ru/*",
    "*://*.yiwugo.com/*",
    "*://*.yiwugou.com/*",
    "https://localhost:3000/*",
    "https://*.vercel.app/*",
    "https://*.crossly.cn/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.1688.com/*", "*://*.ozon.ru/*", "*://*.yiwugo.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
